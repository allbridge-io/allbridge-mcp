    "@stellar/stellar-sdk": "^15.0.1",
    "algosdk": "3.5.2",
    "axios": "1.15.1",
    "bs58": "6.0.0",
    "dotenv": "16.6.1",
    "ethers": "6.15.0",
    "express": "5.2.1",
    "tronweb": "6.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.18.0",
    "@typescript-eslint/eslint-plugin": "8.42.0",
    "@typescript-eslint/parser": "8.42.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "prettier": "3.6.2",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
